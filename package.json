{
  "name": "zcode-proxy",
  "version": "0.0.0.10",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile --define \"require.resolve=undefined\" --target=bun-windows-x64 src/index.ts --outfile zcode-proxy.exe",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "jsdom": "^25.0.0",
    "playwright": "^1.40.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/jsdom": "^28.0.3",
    "typescript": "^5.5.0"
  }
}
